    "organic_results_per_query": 3,
    "google_num": 10,
    "google_queries_extra": [
      "\"{company}\" \"{job_title}\" recruiter site:linkedin.com/in",
      "\"{company}\" VP engineering site:linkedin.com/in"
    ]
  },
  "location_hint": "Israel",
  "filter_jobs_by_location_hint": true,
  "location_hint_strict_location_or_title": true,
  "location_hint_include_job_description": false,
  "location_hint_description_max_chars": 4000,
