{
  "use_serpapi": false,
  "serpapi_features": {
    "google_jobs": false,
    "google_site_ats": false,
    "contacts": false
  },
  "email_from_display_name": "Job Agent",
  "email_attach_excel": false,
  "email_table_headers": {
    "Link": "Job link / URL"
  },
  "excel_column_labels": {
    "Link": "Job link / URL"
  },
