# Copy to .env and fill in real values
# Optional: force-disable SerpAPI (e.g. monthly quota exhausted). Overrides use_serpapi in config.
# JOB_AGENT_NO_SERPAPI=1
# Optional: SerpAPI — only used when config.json has "use_serpapi": true
# SERPAPI_KEY=
# GOOGLE_JOBS_API_KEY=

EMAIL_USER=
EMAIL_PASS=
EMAIL_TO=

# Optional: display name in From header (overrides config email_from_display_name). Default: Job Agent.
EMAIL_FROM_DISPLAY=

# Optional: shared JSON settings (Azure Functions style)
GENIE4CV_SETTINGS=/Users/arkadiykats/genie4cv/local.settings.json
