{
  "use_serpapi": false,
  "serpapi_features": {
    "google_jobs": true,
    "google_site_ats": true,
    "contacts": false
  },
  "email_from_display_name": "Job Agent",
  "email_attach_excel": false,
  "email_table_headers": {
    "Link": "Job link / URL"
  },
  "excel_column_labels": {
    "Link": "Job link / URL"
  },
  "network": {
    "linkedin_connections_csv": ""
  },
  "contact_search": {
    "top_jobs_for_contacts": 8,
    "max_contacts_per_job": 4,
    "max_contacts_total": 32,
    "organic_results_per_query": 3,
    "google_num": 10,
    "google_queries_extra": [
      "\"{company}\" \"{job_title}\" recruiter site:linkedin.com/in",
      "\"{company}\" VP engineering site:linkedin.com/in"
    ]
  },
  "location_hint": "Israel",
  "filter_jobs_by_location_hint": true,
  "digest_email_enforce_location_hint": true,
  "location_hint_strict_location_or_title": true,
  "location_hint_include_job_description": false,
  "location_hint_description_max_chars": 4000,
  "location_hint_aliases": [
    "israel",
